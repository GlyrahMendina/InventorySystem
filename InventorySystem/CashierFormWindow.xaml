<Window x:Class="InventorySystem.CashierFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cashier Form"
        Height="700"
        Width="420"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <Grid Margin="30">
        <StackPanel>
            <TextBlock x:Name="txtTitle"
                       Text="Add Cashier"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#FF6A1A"
                       Margin="0,0,0,20"/>

            <TextBlock Text="First Name"/>
            <TextBox x:Name="txtFirstName" Height="35" Margin="0,5,0,10"/>

            <TextBlock Text="Last Name"/>
            <TextBox x:Name="txtLastName" Height="35" Margin="0,5,0,10"/>

            <TextBlock Text="Username"/>
            <TextBox x:Name="txtUsername" Height="35" Margin="0,5,0,10"/>

            <TextBlock Text="Password"/>
            <TextBox x:Name="txtPassword" Height="35" Margin="0,5,0,10"/>

            <TextBlock Text="Contact Number"/>
            <TextBox x:Name="txtContactNumber" Height="35" Margin="0,5,0,10"/>

            <TextBlock Text="Assigned Shift"/>
            <ComboBox x:Name="cmbShift" Height="35" Margin="0,5,0,10">
                <ComboBoxItem Content="Morning Shift"/>
                <ComboBoxItem Content="Afternoon Shift"/>
                <ComboBoxItem Content="Evening Shift"/>
            </ComboBox>

            <TextBlock Text="Status"/>
            <ComboBox x:Name="cmbStatus" Height="35" Margin="0,5,0,20">
                <ComboBoxItem Content="Active"/>
                <ComboBoxItem Content="Inactive"/>
            </ComboBox>

            <Button Content="Save"
                    Height="45"
                    Background="#FF6A1A"
                    Foreground="White"
                    FontSize="18"
                    FontWeight="Bold"
                    Click="btnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>