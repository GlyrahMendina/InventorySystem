<UserControl x:Class="InventorySystem.AddCashierPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="45,35,45,35">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Add Cashier"
                   Foreground="#FF6A1A"
                   FontSize="40"
                   FontWeight="Bold"/>

        <Grid Grid.Row="1">
            <StackPanel Orientation="Horizontal">
                <Button Content="Active" Width="130" Height="40" Background="#38A145" Foreground="White" Click="btnActive_Click"/>
                <Button Content="Inactive" Width="130" Height="40" Background="#FF3131" Foreground="White" Margin="20,0,0,0" Click="btnInactive_Click"/>
                <Button Content="Deleted" Width="130" Height="40" Background="#555" Foreground="White" Margin="20,0,0,0" Click="btnDeleted_Click"/>
            </StackPanel>

            <Button Content="+ Add Cashier"
                    Width="200"
                    Height="45"
                    HorizontalAlignment="Right"
                    Background="#FF6A1A"
                    Foreground="White"
                    FontSize="18"
                    FontWeight="Bold"
                    Click="btnAddCashier_Click"/>
        </Grid>

        <ListView x:Name="lvCashiers"
          Grid.Row="2"
          BorderThickness="0"
          Background="Transparent"
          ScrollViewer.HorizontalScrollBarVisibility="Disabled">

            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Width="340"
                    Height="310"
                    Background="White"
                    BorderBrush="#DADADA"
                    BorderThickness="1"
                    CornerRadius="12"
                    Margin="0,0,25,25"
                    Padding="18">

                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10"
                                      ShadowDepth="2"
                                      Opacity="0.20"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Name + Status -->
                            <!-- Name + Status -->
                            <Grid Margin="0,0,0,5">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Dynamic Name -->
                                <TextBlock Grid.Column="0"
                                   Text="{Binding FullName}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#222"
                                   MaxWidth="210"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>

                                <!-- Status Badge -->
                                <Border Grid.Column="1"
                                    Background="#D8F8E6"
                                    CornerRadius="12"
                                    Padding="12,4"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center">

                                    <TextBlock Text="{Binding StatusText}"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="#087A3A"/>
                                </Border>

                            </Grid>

                            <!-- Email -->
                            <TextBlock Grid.Row="1"
                               Text="{Binding Email}"
                               FontSize="15"
                               Foreground="#666"
                               Margin="0,8,0,15"/>

                            <!-- Details -->
                            <StackPanel Grid.Row="2">

                                <Border Background="#F7F7F7"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,10">
                                    <Grid>
                                        <TextBlock Text="{Binding CashierID}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#444"/>
                                    </Grid>
                                </Border>

                                <Border Background="#EEF5FF"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,10">
                                    <TextBlock Text="{Binding ContactText}"
                                       FontSize="15"
                                       Foreground="#444"/>
                                </Border>

                                <Border Background="#FFF3F3"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,10">
                                    <TextBlock Text="{Binding ShiftText}"
                                       FontSize="15"
                                       Foreground="#444"/>
                                </Border>

                                <Border Background="#F7F7F7"
                                CornerRadius="8"
                                Padding="12">
                                    <TextBlock Text="{Binding DateCreatedText}"
                                       FontSize="14"
                                       Foreground="#555"/>
                                </Border>
                            </StackPanel>

                            <!-- Buttons -->
                            <StackPanel Grid.Row="3"
                                Orientation="Horizontal"
                                Margin="0,15,0,0">

                                <Button Content="Edit"
                                Width="200"
                                Height="38"
                                Background="#22C55E"
                                Foreground="White"
                                FontWeight="Bold"
                                Tag="{Binding userID}"
                                IsEnabled="{Binding IsNotDeleted}"
                                Click="btnEditCashier_Click"/>          

                                <Button Content="Delete"
                                Width="80"
                                Height="38"
                                Background="#EF4444"
                                Foreground="White"
                                FontWeight="Bold"
                                Margin="12,0,0,0"
                                Tag="{Binding userID}"
                                IsEnabled="{Binding IsNotDeleted}"
                                Click="btnDeleteCashier_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>