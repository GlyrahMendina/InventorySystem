<UserControl x:Class="InventorySystem.InventoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Inventory"
                   FontSize="42"
                   FontWeight="Bold"
                   Foreground="#FF6A1A"
                   Margin="0,0,0,25"/>

        <Grid Grid.Row="1" Margin="0,0,0,25">
            <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Left">

                <TextBox x:Name="txtSearch"
                 Width="350"
                 Height="45"
                 VerticalContentAlignment="Center"
                 FontSize="16"
                 Padding="15,0,0,0"
                 TextChanged="txtSearch_TextChanged"/>

                <ComboBox x:Name="cmbCategoryFilter"
                  Width="180"
                  Height="45"
                  Margin="15,0,0,0"
                  FontSize="15"
                  SelectionChanged="cmbCategoryFilter_SelectionChanged"/>
            </StackPanel>

            <Button Content="+ Add Product"
                Width="220"
                Height="45"
                HorizontalAlignment="Right"
                Background="#FF6A1A"
                Foreground="White"
                FontWeight="Bold"
                FontSize="18"
                BorderThickness="0"
                Click="btnAddProduct_Click"/>
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,0,0,25">

            <Button Content="Active"
                    Width="130"
                    Height="42"
                    Background="#3BA745"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="btnActive_Click"/>

            <Button Content="Inactive"
                    Width="130"
                    Height="42"
                    Margin="15,0,0,0"
                    Background="#FF3131"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="btnInactive_Click"/>

            <Button Content="Deleted"
                    Width="130"
                    Height="42"
                    Margin="15,0,0,0"
                    Background="#555555"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="btnDeleted_Click"/>
        </StackPanel>

        <ScrollViewer Grid.Row="3"
                      VerticalScrollBarVisibility="Auto">

            <ListView x:Name="lvProducts"
                      BorderThickness="0"
                      Background="Transparent"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Margin" Value="0,0,20,20"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Width="340"
                                Padding="20"
                                Background="White"
                                CornerRadius="18"
                                BorderBrush="#DDDDDD"
                                BorderThickness="1">

                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10"
                                                  ShadowDepth="2"
                                                  Opacity="0.15"/>
                            </Border.Effect>

                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="{Binding ProductName}"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="#222"
                                               Width="210"
                                               TextTrimming="CharacterEllipsis"/>

                                    <Border Background="#D9F2E3"
                                            CornerRadius="12"
                                            Padding="14,5"
                                            HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding Status}"
                                                   Foreground="#178344"
                                                   FontWeight="Bold"/>
                                    </Border>
                                </Grid>

                                <TextBlock Text="{Binding Category}"
                                           FontSize="16"
                                           Foreground="#777"
                                           Margin="0,10,0,18"/>

                                <Border Background="#EEF3FA"
                                        CornerRadius="12"
                                        Padding="15"
                                        Margin="0,0,0,12">
                                    <Grid>
                                        <TextBlock Text="Price"
                                                   FontSize="17"
                                                   Foreground="#444"
                                                   HorizontalAlignment="Left"/>

                                        <TextBlock Text="{Binding PriceText}"
                                                   FontSize="19"
                                                   FontWeight="Bold"
                                                   Foreground="#2255D8"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>

                                <Border Background="#F5F5F5"
                                        CornerRadius="12"
                                        Padding="15"
                                        Margin="0,0,0,12">
                                    <Grid>
                                        <TextBlock Text="Stock"
                                                   FontSize="17"
                                                   Foreground="#444"
                                                   HorizontalAlignment="Left"/>

                                        <TextBlock Text="{Binding Stock}"
                                                   FontSize="19"
                                                   FontWeight="Bold"
                                                   Foreground="#222"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>

                                <Border Background="#FFF1F1"
                                        CornerRadius="12"
                                        Padding="15"
                                        Margin="0,0,0,20">
                                    <Grid>
                                        <TextBlock Text="Stock Level"
                                                   FontSize="17"
                                                   Foreground="#444"
                                                   HorizontalAlignment="Left"/>

                                        <TextBlock Text="{Binding StockLevel}"
                                                   FontSize="17"
                                                   FontWeight="Bold"
                                                   Foreground="#D62424"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="85"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Content="Edit"
                                            Height="42"
                                            Background="#22C55E"
                                            Foreground="White"
                                            FontWeight="Bold"
                                            BorderThickness="0"
                                            Tag="{Binding ProductID}"
                                            IsEnabled="{Binding CanEdit}"
                                            Click="btnEditProduct_Click"/>

                                    <Button Grid.Column="1"
                                            Content="{Binding ToggleButtonText}"
                                            Height="42"
                                            Margin="10,0,0,0"
                                            Background="#F59E0B"
                                            Foreground="White"
                                            FontWeight="Bold"
                                            BorderThickness="0"
                                            Tag="{Binding ProductID}"
                                            Click="btnToggleProductStatus_Click"/>

                                    <Button Grid.Column="2"
                                            Content="Delete"
                                            Height="42"
                                            Margin="10,0,0,0"
                                            Background="#EF4444"
                                            Foreground="White"
                                            FontWeight="Bold"
                                            BorderThickness="0"
                                            Tag="{Binding ProductID}"
                                            IsEnabled="{Binding CanDelete}"
                                            Click="btnDeleteProduct_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
    </Grid>
</UserControl>