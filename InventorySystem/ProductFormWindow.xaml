<Window x:Class="InventorySystem.ProductFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Product Form"
        Height="650"
        Width="450"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <ScrollViewer>
        <Grid Margin="30">
            <StackPanel>

                <TextBlock x:Name="txtTitle"
                           Text="Add Product"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#FF6A1A"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Product Name"/>
                <TextBox x:Name="txtName" Height="35" Margin="0,5,0,10"/>

                <TextBlock Text="Description"/>
                <TextBox x:Name="txtDescription" Height="35" Margin="0,5,0,10"/>

                <TextBlock Text="Category / Type"/>
                <TextBox x:Name="txtType" Height="35" Margin="0,5,0,10"/>

                <TextBlock Text="Cost"/>
                <TextBox x:Name="txtCost" Height="35" Margin="0,5,0,10"/>

                <TextBlock Text="Selling Price"/>
                <TextBox x:Name="txtSellingPrice" Height="35" Margin="0,5,0,10"/>

                <TextBlock Text="Stock Quantity"/>
                <TextBox x:Name="txtQuantity" Height="35" Margin="0,5,0,10"/>

                <TextBlock Text="Reorder Level"/>
                <TextBox x:Name="txtReorderLevel" Height="35" Margin="0,5,0,10"/>

                <TextBlock Text="Manufacturing Date"/>
                <DatePicker x:Name="dpManufacturingDate" Height="35" Margin="0,5,0,10"/>

                <TextBlock Text="Expiry Date"/>
                <DatePicker x:Name="dpExpiryDate" Height="35" Margin="0,5,0,20"/>

                <Button Content="Save Product"
                        Height="45"
                        Background="#FF6A1A"
                        Foreground="White"
                        FontSize="18"
                        FontWeight="Bold"
                        Click="btnSave_Click"/>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>