<UserControl x:Class="InventorySystem.GeneralReportPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="General Report"
                   FontSize="42"
                   FontWeight="Bold"
                   Foreground="#FF6A1A"
                   Margin="0,0,0,25"/>

        <!-- SUMMARY CARDS -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,25">

            <Border BorderBrush="#999" BorderThickness="1" CornerRadius="8" Background="White" Margin="0,0,20,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="Total Products" FontSize="14" FontWeight="Bold" Foreground="#555"/>
                    <TextBlock x:Name="txtTotalProducts" Text="0" FontSize="40" FontWeight="Bold" Foreground="#FF3131"/>
                </StackPanel>
            </Border>

            <Border BorderBrush="#999" BorderThickness="1" CornerRadius="8" Background="White" Margin="0,0,20,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="Low Stock Items" FontSize="14" FontWeight="Bold" Foreground="#555"/>
                    <TextBlock x:Name="txtLowStock" Text="0" FontSize="40" FontWeight="Bold" Foreground="#F47B20"/>
                </StackPanel>
            </Border>

            <Border BorderBrush="#999" BorderThickness="1" CornerRadius="8" Background="White" Margin="0,0,20,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="Total Sales this Month" FontSize="14" FontWeight="Bold" Foreground="#555"/>
                    <TextBlock x:Name="txtTotalSalesMonth" Text="Php 0.00" FontSize="26" FontWeight="Bold" Foreground="#38A145"/>
                </StackPanel>
            </Border>

            <Border BorderBrush="#999" BorderThickness="1" CornerRadius="8" Background="White" Padding="15">
                <StackPanel>
                    <TextBlock Text="Transactions Today" FontSize="14" FontWeight="Bold" Foreground="#555"/>
                    <TextBlock x:Name="txtTransactionsToday" Text="0" FontSize="40" FontWeight="Bold" Foreground="#555"/>
                </StackPanel>
            </Border>

        </UniformGrid>

        <!-- BODY -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CHART AREA -->
            <Border Grid.Column="0"
                    BorderBrush="#999"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="White"
                    Margin="0,0,25,0"
                    Padding="20">

                <StackPanel>
                    <TextBlock Text="Sales Trend"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#555"
                               Margin="0,0,0,15"/>

                    <Canvas x:Name="chartCanvas"
                            Height="330"
                            Background="White"/>
                </StackPanel>
            </Border>

            <!-- TRANSACTIONS -->
            <Border Grid.Column="1"
                    BorderBrush="#999"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="White"
                    Padding="20">

                <StackPanel>
                    <TextBlock Text="Transactions"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#555"
                               Margin="0,0,0,15"/>

                    <ListView x:Name="lvTransactions"
                              BorderThickness="0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#DDD"
                                        BorderThickness="0,0,0,1"
                                        Padding="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="{Binding OrderText}"
                                                       FontWeight="Bold"
                                                       FontSize="14"/>
                                            <TextBlock Text="{Binding DateText}"
                                                       Foreground="#777"
                                                       FontSize="12"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding TotalText}"
                                                   FontWeight="Bold"
                                                   Foreground="#38A145"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>